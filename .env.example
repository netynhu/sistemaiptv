# Supabase — copie de Project Settings > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Segredo do webhook da Uazapi (invente um valor aleatório e use o mesmo na URL do webhook)
WEBHOOK_SECRET=troque-por-um-segredo-aleatorio

# Segredo da automação diária (n8n) — invente um valor aleatório e use o mesmo no fluxo n8n
AUTOMACAO_SECRET=troque-por-outro-segredo-aleatorio
